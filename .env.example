# Production site origin with no trailing slash. Used for:
# - PRIVACY_POLICY_PUBLIC_URL / TERMS_PUBLIC_URL / SITE_HOME_URL (src/config.js)
# - Injected og:url, og:image, twitter:image at build time (vite.config.js)
# - Client-side <link rel="canonical"> on home + legal routes
#
# Also add public/og-image.png (~1200×630) for social previews (referenced when this is set).
# VITE_SITE_ORIGIN=https://ika.design

# Contact / Support mailto (no "mailto:" prefix). Required for a working Contact link in the browser.
# VITE_SUPPORT_EMAIL=you@yourdomain.com
